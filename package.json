{
  "name": "mortgage-renewal-hub",
  "type": "module",
  "version": "1.0.0",
  "author": "MortgageRenewalHub.ca",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-page-dates.mjs",
    "build": "astro build",
    "postbuild": "node vercel/ping-indexnow.mjs || true",
    "indexnow": "node vercel/ping-indexnow.mjs",
    "generate:pdf": "node scripts/generate-renewal-checklist-pdf.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.astro --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "automation": "npx tsx scripts/automation",
    "linker:check": "npx tsx scripts/automation -f linker-v4 -m validate --all",
    "linker:catalog": "npx tsx scripts/automation -f linker-v4 -m build-catalog"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^7.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.23.0",
    "nylas": "^8.4.0",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "pdfkit": "^0.19.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0"
  }
