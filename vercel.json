    },
    {
      "source": "/should-i-switch-quiz/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    }
  ],
  "redirects": [
    { "source": "/faq", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/faq/", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal/", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation/", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal", "destination": "/manitoba-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal/", "destination": "/manitoba-mortgage-renewal/", "permanent": true }
  ]
}
