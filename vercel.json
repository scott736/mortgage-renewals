{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap-(.*).xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/:slug(best-mortgage-renewal-rates|current-mortgage-rates-canada|mortgage-rate-forecast){/}?",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/:slug(mortgage-renewal-calculator|mortgage-stress-test-calculator|amortization-schedule-calculator|blend-and-extend-calculator|rate-comparison-calculator|accelerated-payment-calculator|heloc-vs-refinance-calculator|mortgage-payment-frequency-canada|break-even-switch-calculator|switch-vs-stay-calculator|mortgage-penalty-calculator|refinance-debt-consolidation-calculator|rental-income-qualifying-calculator|prepayment-lump-sum-calculator|affordability-requalification-calculator|renewal-document-checklist-generator|should-i-switch-quiz){/}?",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }
      ]
    }
  ],
  "redirects": [
    { "source": "/faq", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/faq/", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal/", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation/", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal", "destination": "/manitoba-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal/", "destination": "/manitoba-mortgage-renewal/", "permanent": true }
  ]
}
