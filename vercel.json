{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap-(.*).xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/faq", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/faq/", "destination": "/mortgage-renewal-faq/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/investment-property-mortgage-renewal/", "destination": "/investment-property-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/mortgage-renewal-divorce-separation/", "destination": "/divorce-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal", "destination": "/manitoba-mortgage-renewal/", "permanent": true },
    { "source": "/saskatchewan-manitoba-mortgage-renewal/", "destination": "/manitoba-mortgage-renewal/", "permanent": true }
  ]
}
