    },
    {
      "source": "/mortgage-penalty-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/refinance-debt-consolidation-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/rental-income-qualifying-calculator/?",
