    },
    {
      "source": "/blend-and-extend-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/rate-comparison-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/accelerated-payment-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/heloc-vs-refinance-calculator/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/mortgage-payment-frequency-canada/?",
      "headers": [{ "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=600" }]
    },
    {
      "source": "/break-even-switch-calculator/?",
