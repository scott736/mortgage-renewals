---
export const prerender = false;

import AuthorByline from "@/components/AuthorByline.astro";
import RelatedLinks from "@/components/RelatedLinks.astro";
import { SchedulingWidgetWithBoundary } from '@/components/scheduling/scheduling-with-boundary';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { services, teamMembers } from '@/lib/nylas/config';
import { breadcrumbSchema, combineSchemas,serviceSchema, webPageNode } from '@/lib/schema';

const schema = combineSchemas(
  webPageNode({
    slug: "book-a-call",
    name: "Book a Free Mortgage Renewal Strategy Call",
    description: "Schedule a free 30-minute call with a licensed Canadian mortgage broker to review your renewal options.",
  }),
  serviceSchema({
    name: "Free Mortgage Renewal Strategy Call",
    description: "A complimentary 30-minute consultation with a licensed Canadian mortgage broker who will compare rates from 30+ lenders, review your renewal options, and build a personalized strategy. No fee, no obligation.",
    slug: "book-a-call",
    serviceType: "Mortgage Broker Consultation",
    price: "0",
    priceCurrency: "CAD",
  }),
  breadcrumbSchema([
    { name: "Book a Call", url: "/book-a-call" }
  ]),
);
---

<DefaultLayout
  title="Book a Free Renewal Strategy Call — MortgageRenewalHub.ca"
  description="Speak with a licensed Canadian mortgage professional about your renewal. Free, no obligation — we'll compare rates from 30+ lenders and build your strategy."
  schema={schema}
  preloadImage="/images/hero/hero-broker.webp"
  hideAuthorByline={true}
>
  <section class="section-padding py-16">
    <div class="container max-w-screen-xl">
      <div class="max-w-2xl mx-auto mb-8">
        <AuthorByline showPhoto={true} />
      </div>
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 rounded-full bg-secondary-25 px-4 py-1.5 text-body-sm-medium text-secondary-200 mb-4">
          Free · No Obligation · Licensed Professionals
        </div>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Book Your Free Renewal Strategy Call</h1>
        <p class="mt-4 text-lg text-muted-foreground max-w-2xl mx-auto">
          Our licensed mortgage professionals will review your options, compare rates across 30+ lenders, and build a personalized strategy — completely free.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-6 text-body-sm text-muted-foreground">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-100" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            30-minute call
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-100" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Access to 30+ lenders
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-secondary-100" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Zero broker fees
          </div>
        </div>
      </div>

      <div class="max-w-2xl mx-auto mb-8 rounded-xl border border-gray-100 bg-gray-25 p-6 text-left">
        <h2 class="text-heading-5 mb-3">What to bring to your call</h2>
        <ul class="space-y-2 text-body-sm text-muted-foreground list-disc list-inside">
          <li>Most recent mortgage statement (balance, maturity date, charge type)</li>
          <li>Renewal letter or rate offer from your bank, if you have it</li>
          <li>Rough income docs (T4, NOA, or business financials if self-employed)</li>
          <li>Your target: lower payment, lowest rate, or access equity</li>
        </ul>
        <p class="text-body-xs text-muted-foreground mt-3">
          No credit pull until you authorize a formal application. See <a href="/pricing/" class="text-secondary-100 hover:underline">how broker pricing works</a>.
        </p>
      </div>

      <SchedulingWidgetWithBoundary
        client:visible
        services={services}
        teamMembers={teamMembers}
        initialServiceId="renewal-strategy-call"
        initialRegion="canada"
      />

      <p class="mt-8 text-center text-body-xs text-muted-foreground max-w-xl mx-auto">
        This content is for educational purposes only and does not constitute financial or mortgage advice. Always consult a licensed mortgage professional for advice specific to your situation.
      </p>

      <RelatedLinks slug="/book-a-call/" />
    </div>
  </section>
</DefaultLayout>
