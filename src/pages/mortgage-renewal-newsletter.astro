---
import NewsletterSignup from '@/components/interactive/newsletter-signup';
import RelatedLinks from "@/components/RelatedLinks.astro";
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { articleSchema, breadcrumbSchema, combineSchemas,faqSchema, webPageNode } from '@/lib/schema';

export const prerender = true;

const faqs = [
  {
    question: "How often will I receive emails?",
    answer: "The core newsletter ships once a week — typically Thursday morning Eastern Time. Around Bank of Canada rate announcement days (there are eight per year) you may receive a second same-week 'Rate Watch' update within 24 hours of the decision. That's the maximum frequency; we will never send more than twice in a week."
  },
  {
    question: "Is this CASL-compliant?",
    answer: "Yes. Under Canada's Anti-Spam Legislation, we require express written consent before sending commercial electronic messages. Signing up with the consent checkbox ticked, plus clicking the double opt-in confirmation link in our first email, satisfies CASL express consent requirements. Every email thereafter includes the sender identification, physical mailing address, and a one-click unsubscribe link as required by law."
  },
  {
    question: "What will you do with my email address?",
    answer: "We use your email solely to deliver the newsletter and, if you've given optional province data, to tailor the rate and regulatory content to your province. We do not sell, rent, or share your email with third parties. The newsletter platform (currently Resend / MailerLite) processes the mailing on our behalf under standard data-processing terms. See our privacy policy for full detail."
  },
  {
    question: "Can I unsubscribe easily?",
    answer: "Yes, and instantly. Every email includes a one-click unsubscribe link at the bottom. Clicking it removes you from the list within 10 business days (usually within minutes), as required by CASL. You can also email us at hello@mortgagerenewalhub.ca with 'unsubscribe' in the subject line."
  },
  {
    question: "Does subscribing commit me to anything?",
    answer: "Absolutely not. The newsletter is educational content only — there's no obligation to use any mortgage product, work with any broker, or make any purchase. Many of our subscribers are simply curious Canadian homeowners tracking the rate environment. Read as long as it's useful and unsubscribe when it's not."
  }
];

const schema = combineSchemas(
  articleSchema({
    headline: "Canadian Mortgage Renewal Newsletter (2026)",
    description: "Weekly Canadian mortgage renewal newsletter — rate moves, Bank of Canada decisions, renewal tactics. Free, CASL-compliant, one-click unsubscribe.",
    slug: "mortgage-renewal-newsletter",
    articleSection: "Resources",
    about: "Canadian mortgage renewal newsletter",
    keywords: ["mortgage renewal newsletter", "Canadian mortgage email", "rate alert newsletter", "BoC rate decision email"],
  }),
  breadcrumbSchema([
    { name: "Newsletter", url: "/mortgage-renewal-newsletter" }
  ]),
  faqSchema(faqs, "mortgage-renewal-newsletter"),
  webPageNode({
    slug: "mortgage-renewal-newsletter",
    name: "Canadian Mortgage Renewal Newsletter",
    description: "Free weekly Canadian mortgage renewal newsletter — rate moves, Bank of Canada decisions, renewal tactics. CASL-compliant, one-click unsubscribe.",
  }),
);
---

<DefaultLayout
  title="Canadian Mortgage Renewal Newsletter | Free Weekly Email"
  description="Free weekly Canadian mortgage renewal newsletter — rate moves, Bank of Canada decisions, renewal tactics. CASL-compliant, one-click unsubscribe."
  schema={schema}
>
  <nav class="container py-4 text-body-sm text-muted-foreground">
    <a href="/" class="hover:underline">Home</a> › Newsletter
  </nav>

  <section class="container max-w-4xl py-10">
    <div class="mb-8">
      <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Free Weekly Newsletter</div>
      <h1 class="text-heading-1 mb-4">The Canadian Mortgage Renewal Newsletter</h1>
      <p class="text-body-lg text-muted-foreground max-w-2xl">
        The one email a week that Canadian homeowners read before their renewal. Rate moves, Bank of Canada decisions, negotiation tactics, and timely reminders — distilled into a five-minute read.
      </p>
    </div>

    <div class="rounded-xl bg-gray-25 border border-gray-100 p-6 mb-10 key-takeaways">
      <h2 class="text-heading-4 mb-3">What You Get</h2>
      <ul class="space-y-2 text-body-sm leading-relaxed">
        <li>• <strong>Weekly rate snapshot</strong> — where 1, 2, 3, 4, and 5-year fixed rates sit at the Big 6 and top monolines.</li>
        <li>• <strong>Bank of Canada coverage</strong> — same-day analysis of the eight annual overnight rate decisions.</li>
        <li>• <strong>Renewal tactic of the week</strong> — one concrete, actionable tip drawn from broker experience.</li>
        <li>• <strong>New content alerts</strong> — first to see new calculators, videos, and guides.</li>
        <li>• <strong>CASL-compliant</strong> — express opt-in, one-click unsubscribe, no email list sharing.</li>
      </ul>
    </div>

    <NewsletterSignup client:load />

    <h2 class="text-heading-3 mt-12 mb-4">Sample Past Issues</h2>
    <p class="text-body-md mb-6 leading-relaxed">
      Here's a taste of what lands in your inbox. Each issue is designed to be read on a phone in five minutes or less.
    </p>

    <div class="grid gap-4 mb-8">
      <div class="rounded-xl border border-gray-100 bg-white p-5">
        <div class="text-body-xs-medium text-secondary-100 uppercase tracking-wide mb-1">Issue #14 · April 4, 2026</div>
        <h3 class="font-semibold mb-2">The 120-day window closes in three weeks — here's what to lock now</h3>
        <p class="text-body-sm text-muted-foreground">
          This week the 5-year fixed dropped another 7 bps at three major monolines as GoC 5-year bonds softened post-U.S. data. Anyone renewing in May or June should be looking at rate holds this week — the April 29 BoC decision is the next potential catalyst. Three specific lenders to watch and a script for your retention call. (Full issue covers rate table, BoC preview, listener question on HELOC at renewal.)
        </p>
      </div>

      <div class="rounded-xl border border-gray-100 bg-white p-5">
        <div class="text-body-xs-medium text-secondary-100 uppercase tracking-wide mb-1">Issue #13 · March 28, 2026</div>
        <h3 class="font-semibold mb-2">Your bank's renewal letter says 4.74%. The broker quote says 4.04%. Now what?</h3>
        <p class="text-body-sm text-muted-foreground">
          An Ottawa reader's actual situation walks through the negotiation sequence step by step. We share the exact email template (now posted on the site), the retention response, and the final rate outcome. Also in this issue: updates to the BoC's March Monetary Policy Report, and why fixed rates behaved differently from variable this cycle.
        </p>
      </div>

      <div class="rounded-xl border border-gray-100 bg-white p-5">
        <div class="text-body-xs-medium text-secondary-100 uppercase tracking-wide mb-1">Issue #12 · March 21, 2026</div>
        <h3 class="font-semibold mb-2">The OSFI straight-switch rule is still confusing lenders — here's how to use it</h3>
        <p class="text-body-sm text-muted-foreground">
          Sixteen months after OSFI exempted straight-switch renewals from the stress test, some lenders still run a full B-20 qualification by habit. This issue explains what your broker should be saying to the lender to invoke the exemption, and includes two reader screenshots showing denied-then-approved outcomes. Also: a primer on the April 29 BoC decision expectations.
        </p>
      </div>
    </div>

    <h2 class="text-heading-3 mt-10 mb-4">Who Writes It</h2>
    <p class="text-body-md mb-4 leading-relaxed">
      The newsletter is written by Scott Dillingham, principal broker at LendCity Mortgages and the named expert author for MortgageRenewalHub.ca. Every week includes at least one tactic drawn from an actual current client file — anonymised, but real. When the BoC moves, you hear the broker channel's same-day read — not a copy-paste of a press release.
    </p>

    <h2 class="text-heading-3 mt-10 mb-4">Privacy and CASL Compliance</h2>
    <p class="text-body-md mb-4 leading-relaxed">
      MortgageRenewalHub.ca operates in Canada and complies with the Canada Anti-Spam Legislation (CASL) and federal and provincial privacy laws. We collect your email address for the sole purpose of delivering this newsletter. We never sell, rent, or share it. The newsletter platform processes the mailing on our behalf under standard data-processing terms.
    </p>

    <p class="text-body-md mb-4 leading-relaxed">
      Subscribing uses an <strong>express double opt-in</strong> — you click the consent checkbox, then confirm via a link in our first email. Every subsequent email includes our physical mailing address (LendCity Mortgages · 4769 Wyandotte St E, Windsor, ON N8T 1E6) and a one-click unsubscribe link. Unsubscribes are honoured within 10 business days (typically within minutes).
    </p>

    <p class="text-body-md mb-6 leading-relaxed">
      Full detail: <a href="/privacy/" class="text-secondary-100 hover:underline">privacy policy</a>.
    </p>

    <h2 class="text-heading-3 mt-10 mb-4">How to Unsubscribe</h2>
    <p class="text-body-md mb-4 leading-relaxed">
      Three ways, all equally fast:
    </p>
    <ul class="list-disc list-inside mb-6 space-y-2 text-body-md leading-relaxed">
      <li><strong>One-click unsubscribe link</strong> at the bottom of every email — click once and you're out.</li>
      <li><strong>Email us</strong> at hello@mortgagerenewalhub.ca with "unsubscribe" in the subject line.</li>
      <li><strong>Reply to any newsletter</strong> with "unsubscribe" — our team monitors replies.</li>
    </ul>

    <h2 class="text-heading-3 mt-10 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-4 mb-10">
      {faqs.map(f => (
        <details class="rounded-xl border border-gray-100 bg-white p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex justify-between items-center">
            <span>{f.question}</span>
            <span class="text-secondary-100 group-open:rotate-45 transition-transform text-xl leading-none">+</span>
          </summary>
          <p class="mt-3 text-body-md text-muted-foreground">{f.answer}</p>
        </details>
      ))}
    </div>

    <RelatedLinks slug="/mortgage-renewal-newsletter/" />
  </section>

  <section class="bg-primary-100 py-12 mt-10">
    <div class="container max-w-3xl text-center">
      <h2 class="text-heading-3 text-white mb-3">Have a specific renewal coming up?</h2>
      <p class="text-white/80 mb-6">Don't wait for the newsletter — book a free call with a licensed <a href="/mortgage-broker-renewal/" class="text-white underline">mortgage broker</a> for tailored advice on your exact file.</p>
      <a href="/book-a-call/">
        <button class="rounded-lg bg-warning-100 hover:bg-warning-50 text-gray-900 font-semibold px-8 py-4 text-lg transition-colors">
          Book Your Free Call
        </button>
      </a>
    </div>
  </section>
</DefaultLayout>
