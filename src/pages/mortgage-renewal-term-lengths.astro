            </a>
            <a href="/mortgage-renewal-calculator/" class="rounded-lg p-4" style="border: 1px solid var(--border); background: var(--card)">
              <p class="font-semibold text-sm mb-1" style="color: var(--primary)">Mortgage Renewal Calculator</p>
              <p class="text-xs" style="color: var(--muted-foreground)">Model your new payment across different terms and rates.</p>
            </a>
