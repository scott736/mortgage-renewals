              <p class="text-xs" style="color: var(--muted-foreground)">40+ Canadian mortgage terms explained clearly.</p>
            </a>
            <a href="/mortgage-broker-renewal/" class="rounded-lg p-4" style="border: 1px solid var(--border); background: var(--card)">
              <p class="font-semibold text-sm mb-1" style="color: var(--primary)">Using a Mortgage Broker at Renewal</p>
              <p class="text-xs" style="color: var(--muted-foreground)">How brokers compare every term from 30+ lenders — free of charge.</p>
            </a>
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="w-full lg:w-64 flex-shrink-0">
        <div class="sticky top-6 space-y-6">
          <div class="rounded-lg p-5" style="background: var(--accent); border: 1px solid var(--border)">
            <h3 class="font-bold mb-3" style="color: var(--primary)">Quick Navigation</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="#" style="color: var(--secondary)">Term vs. Amortization</a></li>
