---
import FaqDetails from "@/components/FaqDetails.astro";
import HeroImage from "@/components/HeroImage.astro";
import RelatedLinks from "@/components/RelatedLinks.astro";
import RenewalDateCta from '@/components/lead/renewal-date-cta';
import RenewalCalculatorMini from '@/components/sections/renewal-calculator-mini';
import ReviewsSection from '@/components/sections/reviews-section';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getPageMeta } from '@/lib/page-meta';
import { articleSchema, combineSchemas,faqSchema, webPageNode } from '@/lib/schema';

export const pageMeta = getPageMeta("", {
  dateModified: "2026-07-04",
});

const homeFaqs = [
  { question: "What are the best mortgage renewal rates in Canada for 2026?", answer: "As of July 2026, the best insured 5-year fixed renewal rates through mortgage brokers are approximately 4.04%, with 5-year variable around prime minus 1.10% (effective ~3.35% at prime 4.45%). Big Six banks typically quote 0.25–0.75% higher on renewal letters. Compare broker rates on our best renewal rates page before signing your bank's first offer." },
  { question: "Do I have to pass a stress test to switch lenders at renewal?", answer: 'No. Since November 2024, Canadians switching lenders on a straight transfer (same balance, same amortization) do not need to pass the <a href="https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/residential-mortgage-underwriting-practices-procedures-guideline-b-20" target="_blank" rel="noopener noreferrer" class="text-secondary-100 hover:underline">OSFI B-20</a> mortgage stress test. See our <a href="/stress-test-mortgage-renewal/" class="text-secondary-100 hover:underline">stress test at renewal guide</a> for details.' },
  { question: "How much can I save by shopping around at renewal?", answer: "Significantly. Even a 0.25% rate difference saves approximately $7,500 in interest over 5 years on a $600,000 mortgage. Canadians who shop around through a broker typically save 0.25–0.75% vs. their bank's first offer." },
  { question: "Is a mortgage broker free to use?", answer: "Yes, in virtually all cases. Mortgage brokers are paid a finder's fee by the lender you ultimately choose — you pay nothing. Their service, advice, and access to 30+ lenders is free to you." },
  { question: "What happens if I do nothing at renewal?", answer: "Your mortgage automatically renews at whatever rate your lender chooses — almost always the posted rate, which is nearly always the worst rate available. This is the most expensive option." },
  { question: "When should I start thinking about my renewal?", answer: "12 months before your maturity date gives you the most options. At 120 days out, you can lock in a rate hold. At 30 days out, you should be finalizing your lender choice." },
];

const schema = combineSchemas(
  webPageNode({
    slug: "",
    name: "Mortgage Renewal Canada 2026 — Best Rates & Free Expert Guide",
    description: "Best mortgage renewal rates Canada 2026. Compare fixed and variable renewal rates, use free calculators, and get expert broker guidance to save thousands.",
    speakableSelectors: ["h1", "[data-speakable]", ".key-takeaways"],
  }),
  articleSchema({
    headline: "Mortgage Renewal Canada 2026 — Best Rates & Guide",
    description: "Best mortgage renewal rates Canada 2026. Roughly 1 million households renewing (CMHC). Compare rates, use free calculators, and get expert guidance to save thousands.",
    slug: "",
    articleSection: "Mortgage Renewal",
    about: "Canadian Mortgage Renewal",
    keywords: ["mortgage renewal Canada 2026", "best mortgage renewal rates Canada", "mortgage renewal rates", "mortgage broker"],
    dateModified: pageMeta.dateModified,
  }),
  faqSchema(homeFaqs, ""),
);
---

<DefaultLayout
  hideAuthorByline
  title="Mortgage Renewal Canada 2026 — Best Rates & Guide"
  description="Best mortgage renewal rates Canada 2026. Compare fixed & variable rates, free calculators, and broker guidance — save thousands vs. your bank's first offer."
  preloadImage="/images/hero/hero-home.webp"
  schema={schema}
>
  <!-- HERO -->
  <section class="bg-primary-100 text-primary-foreground py-20 lg:py-28">
    <div class="container max-w-screen-xl px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-body-sm text-white/90 mb-6">
            🇨🇦 Canada's #1 Mortgage Renewal Resource
          </div>
          <h1 class="text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            Mortgage Renewal Canada 2026
          </h1>
          <p class="text-xl text-white/80 mb-4 max-w-lg" data-speakable>
            <strong>Best mortgage renewal rates Canada</strong> start around 4.04% (5-year fixed insured) and 3.35% (5-year variable) through brokers in July 2026 — but over 70% of Canadians sign their bank's first offer and overpay by thousands. Compare rates, use our free calculators, and talk to a licensed broker at no cost.
          </p>
          <p class="text-lg text-white/70 mb-8 max-w-lg">
            Roughly 1 million Canadian households are expected to renew in 2026 (<a href="https://www.cmhc-schl.gc.ca/professionals/housing-markets-data-and-research/housing-research/research-reports/housing-finance/residential-mortgage-industry-report" target="_blank" rel="noopener noreferrer" class="text-white underline">CMHC Spring 2026 RMIR</a>). Read our <a href="/mortgage-renewal-guide/" class="text-white underline">complete renewal guide</a> or see <a href="/best-mortgage-renewal-rates/" class="text-white underline">today's best renewal rates</a>.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/book-a-call/">
              <button class="rounded-lg bg-warning-100 hover:bg-warning-50 text-gray-900 font-semibold px-8 py-4 text-lg transition-colors shadow-md">
                Talk to a Broker — Free
              </button>
            </a>
            <a href="/mortgage-renewal-calculator/">
              <button class="rounded-lg border-2 border-white/50 hover:border-white text-white font-semibold px-8 py-4 text-lg transition-colors">
                Use Our Calculator
              </button>
            </a>
          </div>
          <p class="mt-4 text-body-sm text-white/60">Free broker consultation · No obligation · Licensed professionals</p>
          <RenewalDateCta client:visible variant="light" />
        </div>
        <div class="hidden lg:block">
          <HeroImage
            src="/images/hero/hero-home.webp"
            alt="Canadian couple reviewing mortgage renewal documents"
            width={600}
            height={400}
            priority
            class="rounded-2xl shadow-2xl w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="border-b py-6 bg-gray-25">
    <div class="container max-w-screen-xl px-6">
      <div class="flex flex-wrap items-center justify-center gap-8 text-body-sm text-muted-foreground">
        <div class="flex items-center gap-2">
          <a href="https://www.canada.ca/en/financial-consumer-agency/services/mortgages.html" target="_blank" rel="noopener noreferrer" class="font-semibold text-foreground hover:underline">FCAC</a>
          <span>Referenced</span>
        </div>
        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
        <div class="flex items-center gap-2">
          <a href="https://www.cmhc-schl.gc.ca/professionals/housing-markets-data-and-research/housing-research/research-reports/housing-finance/residential-mortgage-industry-report" target="_blank" rel="noopener noreferrer" class="font-semibold text-foreground hover:underline">CMHC</a>
          <span>Verified Data</span>
        </div>
        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
        <div class="flex items-center gap-2">
          <a href="https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/residential-mortgage-underwriting-practices-procedures-guideline-b-20" target="_blank" rel="noopener noreferrer" class="font-semibold text-foreground hover:underline">OSFI</a>
          <span>Compliant Information</span>
        </div>
        <div class="w-px h-4 bg-gray-200 hidden sm:block"></div>
        <div class="flex items-center gap-2">
          <span class="text-secondary-100">✓</span>
          <span>Reviewed by Licensed Mortgage Professionals</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ANSWER CAPSULE -->
  <section class="border-b py-10 bg-white">
    <div class="container max-w-screen-xl px-6">
      <div class="max-w-4xl mx-auto rounded-xl border border-secondary-50 bg-secondary-0 p-6 key-takeaways">
        <h2 class="text-heading-4 mb-3">Mortgage Renewal Canada 2026 — Quick Answer</h2>
        <ul class="space-y-2 text-body-md text-muted-foreground">
          <li>• <strong>Best renewal rates (July 2026):</strong> ~4.04% insured 5-year fixed and ~3.35% 5-year variable through brokers; Big Six renewal letters often quote 0.25–0.75% higher.</li>
          <li>• <strong>When to start:</strong> 120 days before maturity to lock a rate hold; shop with a <a href="/mortgage-broker-renewal/" class="text-secondary-100 hover:underline">mortgage broker</a> (free — paid by lender).</li>
          <li>• <strong>Switch lenders:</strong> No <a href="https://www.osfi-bsif.gc.ca/en/guidance/guidance-library/residential-mortgage-underwriting-practices-procedures-guideline-b-20" target="_blank" rel="noopener noreferrer" class="text-secondary-100 hover:underline">OSFI B-20</a> stress test on straight transfers since November 2024 — see our <a href="/switching-lenders-at-renewal/" class="text-secondary-100 hover:underline">switching guide</a>.</li>
          <li>• <strong>First-time buyer?</strong> See <a href="https://firsthomeguide.ca/" target="_blank" rel="noopener" class="text-secondary-100 hover:underline">FirstHomeGuide.ca</a> for purchase basics; renewal help from <a href="https://lendcity.ca/" target="_blank" rel="noopener" class="text-secondary-100 hover:underline">LendCity Mortgages</a>.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 2026 PAYMENT SHOCK -->
  <section class="border-b bg-warning-0 py-12 lg:py-14">
    <div class="container max-w-screen-xl px-6">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <div class="text-body-sm-medium text-warning-200 uppercase tracking-wide mb-3">2026 Renewal Wave</div>
          <h2 class="text-heading-2 mb-4">Facing a Payment Increase at Renewal?</h2>
          <p class="text-body-lg text-muted-foreground mb-4">
            <a href="https://www.cmhc-schl.gc.ca/professionals/housing-markets-data-and-research/housing-research/research-reports/housing-finance/residential-mortgage-industry-report" target="_blank" rel="noopener noreferrer" class="text-secondary-100 hover:underline">CMHC</a> projects roughly one million Canadian households renewing in 2026 — many from 2020–2021 rates near 2%. The <a href="https://www.bankofcanada.ca/" target="_blank" rel="noopener noreferrer" class="text-secondary-100 hover:underline">Bank of Canada</a> has flagged payment shock as a central theme: for most renewers, payments go <strong>up</strong>, not down, unless you shop for a better rate.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/mortgage-renewal-calculator/" class="inline-flex items-center rounded-lg bg-primary-100 text-white px-6 py-3 font-semibold hover:opacity-90 transition-opacity">
              Calculate Your New Payment
            </a>
            <a href="/mortgage-renewal-payment-shock/" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-6 py-3 font-semibold hover:bg-gray-25 transition-colors">
              Payment Shock Guide
            </a>
            <a href="/mortgage-rate-forecast/" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-6 py-3 font-semibold hover:bg-gray-25 transition-colors">
              2026 Rate Forecast
            </a>
          </div>
        </div>
        <div class="grid sm:grid-cols-3 lg:grid-cols-1 gap-4">
          {[
            { stat: "~1M", label: "Households renewing in 2026", sub: '<a href="https://www.cmhc-schl.gc.ca/professionals/housing-markets-data-and-research/housing-research/research-reports/housing-finance/residential-mortgage-industry-report" target="_blank" rel="noopener noreferrer" class="text-secondary-100 hover:underline">CMHC Spring 2026 RMIR</a>' },
            { stat: "10–30%", label: "Typical payment jump for 2020–2021 cohort", sub: "vs. pandemic-era rates" },
            { stat: "$0", label: "Cost to compare with a broker", sub: "Paid by lender on funding" },
          ].map(item => (
            <div class="rounded-xl bg-white border border-warning-50 p-5 text-center lg:text-left lg:flex lg:items-center lg:gap-4">
              <div class="text-3xl font-bold text-primary-100 lg:min-w-[72px]">{item.stat}</div>
              <div>
                <div class="text-sm font-medium text-gray-800">{item.label}</div>
                <div class="text-xs text-gray-500"><Fragment set:html={item.sub} /></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT IS A MORTGAGE RENEWAL -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-screen-xl px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">The Basics</div>
          <h2 class="text-heading-2 mb-4">What Is a Mortgage Renewal?</h2>
          <p class="text-body-lg text-muted-foreground mb-4">
            A mortgage renewal is what happens at the end of your mortgage <strong>term</strong> — not the end of your mortgage entirely. Most Canadians have a 25-year mortgage but a 5-year <a href="/mortgage-renewal-term-lengths/" class="text-secondary-100 hover:underline">term</a>. Every 5 years, that term ends and you renew.
          </p>
          <p class="text-body-lg text-muted-foreground mb-6">
            At renewal, your lender will send you an offer. You can accept it, negotiate for a better rate, or <a href="/switching-lenders-at-renewal/" class="text-secondary-100 hover:underline">switch to a different lender</a> entirely — often with no cost and no stress test required.
          </p>
          <a href="/what-is-a-mortgage-renewal/" class="inline-flex items-center gap-2 text-secondary-100 font-semibold hover:underline">
            Read the Full Guide →
          </a>
        </div>
        <div class="bg-gray-25 rounded-2xl p-8">
          <h3 class="text-heading-5 mb-4">Key Renewal Facts</h3>
          <ul class="space-y-4">
            {[
              { stat: "21 days", label: "Minimum notice your lender must give before renewal (<a href=\"https://www.canada.ca/en/financial-consumer-agency/services/mortgages/renew-mortgage.html\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-secondary-100 hover:underline\">FCAC rule</a>)" },
              { stat: "4–6 months", label: "When lenders must begin outreach under the <a href=\"https://www.canada.ca/en/department-finance/programs/financial-sector-policy/canadian-mortgage-charter.html\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-secondary-100 hover:underline\">Canadian Mortgage Charter</a>" },
              { stat: "$0", label: "What it costs to use a mortgage broker at renewal" },
              { stat: "70%+", label: "Canadians who sign the first offer without shopping — and overpay" },
            ].map(item => (
              <li class="flex items-start gap-4">
                <div class="text-2xl font-bold text-primary-100 min-w-[80px]">{item.stat}</div>
                <div class="text-body-sm text-muted-foreground"><Fragment set:html={item.label} /></div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- #1 MISTAKE CALLOUT -->
  <section class="bg-warning-0 border border-warning-50 mx-6 lg:mx-auto max-w-screen-xl rounded-2xl py-10 px-8 mb-16">
    <div class="container max-w-3xl mx-auto text-center">
      <div class="text-4xl mb-4">⚠️</div>
      <h2 class="text-heading-3 mb-3">The #1 Mistake Canadians Make at Renewal</h2>
      <p class="text-body-lg text-muted-foreground mb-6">
        Over <strong>70% of Canadians sign their bank's first renewal offer without shopping around</strong>. Banks count on this. A 0.5% rate difference on a $600,000 mortgage costs you over $15,000 in extra interest over 5 years. Compare <a href="/best-mortgage-renewal-rates/" class="text-warning-200 hover:underline">today's best renewal rates</a> to see what you could be saving.
      </p>
      <a href="/mortgage-renewal-mistakes/" class="inline-flex items-center gap-2 text-warning-200 font-semibold hover:underline">
        See All 10 Renewal Mistakes to Avoid →
      </a>
    </div>
  </section>

  <!-- MINI CALCULATOR -->
  <section class="py-16 bg-gray-25">
    <div class="container max-w-screen-xl px-6">
      <div class="text-center mb-10">
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Free Tool</div>
        <h2 class="text-heading-2 mb-3">Renewal Snapshot Calculator</h2>
        <p class="text-body-lg text-muted-foreground max-w-2xl mx-auto">
          See your estimated new payment in seconds. Enter your balance, rate, and remaining amortization.
        </p>
      </div>
      <RenewalCalculatorMini client:visible />
      <div class="text-center mt-6">
        <a href="/mortgage-renewal-calculator/" class="inline-flex items-center gap-2 text-secondary-100 font-semibold hover:underline">
          See All 5 Calculators — Including Rate Comparison & Penalty Estimator →
        </a>
      </div>
    </div>
  </section>

  <!-- TOP 5 WAYS TO SAVE -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-screen-xl px-6">
      <div class="text-center mb-12">
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Strategy Guide</div>
        <h2 class="text-heading-2">Top 5 Ways to Save at Renewal</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            number: "01",
            title: "Shop Around — Don't Auto-Renew",
            desc: "Your bank's first offer is almost never their best rate. Getting one competing quote is often enough to save thousands.",
            href: "/best-mortgage-renewal-rates/",
          },
          {
            number: "02",
            title: "Use a Mortgage Broker",
            desc: "Brokers access 30+ lenders simultaneously — including monolines unavailable directly. And their service is free to you.",
            href: "/mortgage-broker-renewal/",
          },
          {
            number: "03",
            title: "Lock in a Rate Hold Early",
            desc: "Start shopping 120 days before your renewal. Lock in today's rate and you're protected if rates rise before your maturity date.",
            href: "/mortgage-renewal-guide/",
          },
          {
            number: "04",
            title: "Know Your Charge Type",
            desc: "Standard charge mortgages switch lenders easily. Collateral charges (TD and some others) require legal fees to move.",
            href: "/switching-lenders-at-renewal/",
          },
          {
            number: "05",
            title: "Consider Your Term Length",
            desc: "A shorter term (1-2 year fixed) may offer a lower rate today and let you lock in again when rates fall further.",
            href: "/mortgage-renewal-term-lengths/",
          },
          {
            number: "06",
            title: "Extend Your Amortization",
            desc: "If cash flow is tight, extending your amortization can reduce your payment by hundreds per month.",
            href: "/lower-mortgage-payments-at-renewal/",
          },
        ].map(item => (
          <a href={item.href} class="group block bg-gray-25 hover:bg-primary-0 rounded-2xl p-6 border border-gray-100 hover:border-primary-50 transition-colors">
            <div class="text-3xl font-bold text-primary-50 mb-3">{item.number}</div>
            <h3 class="text-heading-5 mb-2 group-hover:text-primary-100">{item.title}</h3>
            <p class="text-body-sm text-muted-foreground">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED GUIDES GRID -->
  <section class="py-16 bg-gray-25">
    <div class="container max-w-screen-xl px-6">
      <div class="text-center mb-12">
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Deep Dives</div>
        <h2 class="text-heading-2">Featured Guides</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: "Complete Renewal Guide", desc: "Everything you need to know — from 12 months out to renewal day.", href: "/mortgage-renewal-guide/", badge: "Most Popular" },
          { title: "Best Renewal Rates", desc: "How renewal rates work, why your bank's offer is rarely the best, and where to find better.", href: "/best-mortgage-renewal-rates/", badge: "Rates" },
          { title: "Lower Your Payments", desc: "11 strategies for Canadians who are stretched financially and need payment relief.", href: "/lower-mortgage-payments-at-renewal/", badge: "Affordability" },
          { title: "Switching Lenders", desc: "No stress test required since 2024. Here's the complete step-by-step process.", href: "/switching-lenders-at-renewal/", badge: "Save Money" },
          { title: "Renewal Checklist", desc: "Printable timeline from 12 months before renewal all the way to renewal day.", href: "/mortgage-renewal-checklist/", badge: "Checklist" },
          { title: "Renewal FAQ", desc: "40+ questions answered — from the basics to complex scenarios.", href: "/mortgage-renewal-faq/", badge: "FAQ" },
        ].map(item => (
          <a href={item.href} class="group block bg-white rounded-2xl p-6 border border-gray-100 hover:border-secondary-50 hover:shadow-md transition-all">
            <div class="inline-flex items-center rounded-full bg-secondary-25 px-3 py-1 text-body-xs text-secondary-200 mb-3">
              {item.badge}
            </div>
            <h3 class="text-heading-5 mb-2 group-hover:text-secondary-100">{item.title}</h3>
            <p class="text-body-sm text-muted-foreground">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RENEWAL TIMELINE -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-screen-xl px-6">
      <div class="text-center mb-12">
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Your Renewal Roadmap</div>
        <h2 class="text-heading-2">What to Do — Month by Month</h2>
        <p class="text-body-lg text-muted-foreground max-w-2xl mx-auto mt-3">
          Start 12 months early to maximize your options and savings.
        </p>
      </div>
      <div class="max-w-3xl mx-auto space-y-6">
        {[
          { time: "12 Months Before", color: "bg-primary-0 border-primary-50", dot: "bg-primary-100", actions: ["Locate your mortgage documents (confirm maturity date, balance, charge type)", "Check your credit score for free (Equifax or TransUnion)", "Identify any debts to pay down before renewal"] },
          { time: "6 Months Before", color: "bg-secondary-0 border-secondary-50", dot: "bg-secondary-100", actions: ["Contact a mortgage broker for a free renewal strategy meeting", "Research current market rates", "Decide on preferred term and rate type (fixed vs. variable)"] },
          { time: "120 Days Before", color: "bg-warning-0 border-warning-50", dot: "bg-warning-100", actions: ["Lock in a rate hold with your broker or new lender", "Submit renewal application if switching lenders", "Gather documents: NOA/T4, proof of income, void cheque"] },
          { time: "30 Days Before", color: "bg-success-0 border-success-50", dot: "bg-success-100", actions: ["Confirm approval with new lender (if switching)", "Sign new mortgage commitment", "Confirm new payment amount and start date"] },
        ].map(step => (
          <div class={`rounded-xl border p-6 ${step.color}`}>
            <div class="flex items-start gap-4">
              <div class={`mt-1 w-4 h-4 rounded-full flex-shrink-0 ${step.dot}`}></div>
              <div>
                <h3 class="text-heading-5 mb-3">{step.time}</h3>
                <ul class="space-y-2">
                  {step.actions.map(action => (
                    <li class="flex items-start gap-2 text-body-sm text-muted-foreground">
                      <span class="mt-1 text-xs">✓</span>
                      {action}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/mortgage-renewal-checklist/" class="inline-flex items-center gap-2 text-secondary-100 font-semibold hover:underline">
          Get the Full Printable Checklist →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ ACCORDION -->
  <section class="py-16 bg-gray-25">
    <div class="container max-w-3xl px-6">
      <div class="text-center mb-10">
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Common Questions</div>
        <h2 class="text-heading-2">Mortgage Renewal FAQ</h2>
      </div>
      <div class="space-y-3">
        {homeFaqs.map(faq => (
          <FaqDetails question={faq.question} answer={faq.answer} allowHtml />
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/mortgage-renewal-faq/" class="inline-flex items-center gap-2 text-secondary-100 font-semibold hover:underline">
