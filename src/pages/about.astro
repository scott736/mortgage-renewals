---
import RelatedLinks from "@/components/RelatedLinks.astro";
import { BUSINESS } from "@/consts";
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { articleSchema, breadcrumbSchema, combineSchemas,webPageNode } from '@/lib/schema';

export const prerender = true;

const schema = combineSchemas(
  webPageNode({
    slug: "about",
    name: "About MortgageRenewalHub.ca",
    description: "Independent Canadian mortgage renewal education resource — our mission and team.",
  }),
  articleSchema({
    headline: "About MortgageRenewalHub.ca",
    description: "MortgageRenewalHub.ca is an independent Canadian mortgage renewal education resource. Learn how we help Canadians save thousands at renewal.",
    slug: "about",
  }),
  breadcrumbSchema([{ name: "About", url: "/about" }]),
);
---

<DefaultLayout
  title="About MortgageRenewalHub.ca — Canada's Renewal Resource"
  description="MortgageRenewalHub.ca is an independent Canadian mortgage renewal education resource. Learn how we help Canadians save thousands at renewal."
  schema={schema}
>
  <!-- HERO -->
  <section class="bg-primary-100 py-16 lg:py-24">
    <div class="container max-w-screen-xl px-6">
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold text-white lg:text-5xl leading-tight mb-6">
          About MortgageRenewalHub.ca
        </h1>
        <p class="text-xl text-white/80">
          Canada's most comprehensive mortgage renewal education resource — built to help everyday Canadians make informed decisions and save thousands at renewal.
        </p>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-screen-xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Our Mission</div>
          <h2 class="text-heading-2 mb-6">Helping Canadians Stop Leaving Money on the Table</h2>
          <p class="text-body-lg text-muted-foreground mb-4">
            Over 70% of Canadians sign their bank's first renewal offer without shopping around. Banks know this and count on it. The result? Billions of dollars in unnecessary interest paid by Canadians who simply didn't know they had better options.
          </p>
          <p class="text-body-md text-muted-foreground mb-4">
            MortgageRenewalHub.ca exists to change that. We provide clear, accurate, jargon-free information about mortgage renewals — starting with our <a href="/mortgage-renewal-guide/" style="color: var(--secondary)">complete mortgage renewal guide</a> — so that every Canadian can approach their renewal from a position of knowledge and confidence.
          </p>
          <p class="text-body-md text-muted-foreground">
            Our guides, <a href="/mortgage-renewal-calculator/" style="color: var(--secondary)">calculators</a>, and resources are free. We earn revenue when you choose to <a href="/book-a-call/" style="color: var(--secondary)">book a free consultation</a> with a licensed mortgage broker — but we never pressure, upsell, or compromise the quality of our educational content.
          </p>
        </div>
        <div class="space-y-4">
          {[
            { number: "1.8M+", label: "Canadians renewing mortgages in 2026" },
            { number: "70%+", label: "Who accept the first offer without shopping" },
            { number: "$15,000+", label: "Average amount a 0.5% rate improvement saves over 5 years on a $600K mortgage" },
            { number: "$0", label: "Cost to use a licensed mortgage broker" },
          ].map(item => (
            <div class="flex items-center gap-4 rounded-xl bg-gray-25 border border-gray-100 p-5">
              <div class="text-2xl font-bold text-primary-100 min-w-[80px]">{item.number}</div>
              <div class="text-body-sm text-muted-foreground">{item.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="bg-gray-25 py-16">
    <div class="container max-w-screen-xl px-6">
      <div class="text-center mb-12">
        <h2 class="text-heading-2">What We Provide</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: "📘", title: "In-Depth Guides", desc: "Comprehensive guides covering every aspect of Canadian mortgage renewal — from the basics to complex scenarios like self-employment, bad credit, and investment properties." },
          { icon: "🧮", title: "Free Calculators", desc: "5 Canadian-specific mortgage calculators using accurate semi-annual compounding math — including a Rate Comparison tool and Penalty Estimator." },
          { icon: "📋", title: "Checklists & Tools", desc: "Printable month-by-month renewal checklists, document guides, and comparison templates to keep your renewal on track." },
          { icon: "📍", title: "Provincial Guides", desc: "Province-specific guides for Ontario, BC, Alberta, and other major markets — because mortgage rules and lenders vary by province." },
          { icon: "❓", title: "40+ FAQ Answers", desc: "Honest answers to the most common mortgage renewal questions — including the ones banks hope you won't ask." },
          { icon: "📞", title: "Free Broker Access", desc: "When you're ready to take action, book a free strategy call with a licensed mortgage broker who can compare rates from 30+ lenders." },
        ].map(item => (
          <div class="rounded-xl bg-white border border-gray-100 p-6">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-body-sm text-muted-foreground">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW WE EARN -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-3xl px-6">
      <div class="rounded-xl bg-primary-0 border border-primary-50 p-8">
        <h2 class="text-heading-3 text-primary-100 mb-4">How This Site Works</h2>
        <p class="text-body-lg text-muted-foreground mb-4">
          MortgageRenewalHub.ca is an educational resource powered by <a href="https://lendcity.ca" target="_blank" rel="noopener" style="color: var(--secondary)">LendCity Mortgages</a>, a licensed Canadian mortgage brokerage. Our guides and calculators are free to use and have no conditions attached.
        </p>
        <p class="text-body-md text-muted-foreground mb-4">
          When you book a free strategy call through this site, you're speaking with a licensed mortgage agent on the LendCity team who can compare rates from 30+ lenders on your behalf. Broker services are always free to borrowers in Canada — lenders pay the broker, not you.
        </p>
        <p class="text-body-md text-muted-foreground">
          This means our interests are aligned: the better our information, the more likely you'll find value in speaking with our team. We have no incentive to promote specific lenders or products — only to give you the best possible information.
        </p>
      </div>
    </div>
  </section>

  <!-- EXPERT AUTHOR -->
  <section class="py-16 bg-white" id="scott-dillingham">
    <div class="container max-w-4xl px-6">
      <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Expert Author & Principal Broker</div>
      <h2 class="text-heading-2 mb-8">Meet Scott Dillingham</h2>

      <div class="grid gap-8 sm:grid-cols-[180px_1fr] items-start">
        <div class="rounded-xl border border-gray-100 bg-gray-25 overflow-hidden aspect-square w-full max-w-[180px]">
          {/* TODO: drop a 400x400+ webp/jpg at public/images/about/scott-dillingham.webp to activate the headshot */}
          <img
            src="/images/about/scott-dillingham.webp"
            alt="Scott Dillingham — Principal Broker, LendCity Mortgages"
            width="180"
            height="180"
            loading="lazy"
            decoding="async"
            onerror="this.style.display='none'; this.parentElement.innerHTML='<div class=\'flex h-full w-full items-center justify-center text-gray-400 text-5xl font-bold\'>SD</div>';"
            class="w-full h-full object-cover"
          />
        </div>

        <div>
          <p class="text-body-md text-muted-foreground mb-4">
            Scott Dillingham is the principal broker at <a href="https://lendcity.ca" target="_blank" rel="noopener" style="color: var(--secondary)">LendCity Mortgages</a> and the named expert author for MortgageRenewalHub.ca. Every guide, calculator walkthrough, and renewal scenario on this site is reviewed against the Canadian mortgage rules in force at the time of publication — OSFI B-20, the FCAC Mortgage Consumer Code of Conduct, and lender-specific overlays.
          </p>
          <p class="text-body-md text-muted-foreground mb-4">
            Scott has been active in Canadian mortgage brokering for over a decade, specialising in renewals, switches, and complex-income files across all ten provinces and the territories. He personally reviews the technical accuracy of the content on this site and keeps it current as rules change.
          </p>
          <ul class="text-body-sm text-muted-foreground space-y-1.5 mb-4">
            <li><strong class="text-foreground">Role:</strong> Principal broker, LendCity Mortgages</li>
            <li><strong class="text-foreground">Licence:</strong> {BUSINESS.licensing.regulator} agent #{BUSINESS.licensing.principalBrokerLicence}</li>
            <li><strong class="text-foreground">Focus areas:</strong> Mortgage renewal, refinance, switch strategy, investment properties</li>
            <li><strong class="text-foreground">Based in:</strong> {BUSINESS.address.addressLocality}, Ontario · serving Canada-wide</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href="/book-a-call/" class="inline-flex rounded-lg bg-primary-100 text-white font-semibold px-5 py-2.5 hover:opacity-90 transition-opacity">
              Book a call with Scott's team
            </a>
            <a href="https://lendcity.ca" target="_blank" rel="noopener" class="inline-flex rounded-lg border-2 border-gray-100 text-gray-900 font-semibold px-5 py-2.5 hover:bg-gray-25 transition-colors">
              LendCity.ca →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POWERED BY LENDCITY -->
  <section class="bg-gray-25 py-16">
    <div class="container max-w-3xl px-6 text-center">
      <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Powered By</div>
      <h2 class="text-heading-2 mb-4">LendCity Mortgages</h2>
      <p class="text-body-lg text-muted-foreground mb-6">
        MortgageRenewalHub.ca is owned and operated by <a href="https://lendcity.ca" target="_blank" rel="noopener" style="color: var(--secondary)">LendCity Mortgages</a> — a full-service Canadian mortgage brokerage helping homeowners, investors, and first-time buyers across the country secure better rates and smarter mortgage strategies.
      </p>
      <address class="not-italic text-body-md text-muted-foreground mb-4 leading-relaxed">
        {BUSINESS.address.streetAddress}<br />
        {BUSINESS.address.addressLocality}, Ontario {BUSINESS.address.postalCode}<br />
        <a href={BUSINESS.phone.tel} style="color: var(--secondary)">{BUSINESS.phone.display}</a>
      </address>
      <p class="text-body-sm text-muted-foreground mb-6">
        {BUSINESS.licensing.brokerageName} · {BUSINESS.licensing.regulator} brokerage #{BUSINESS.licensing.brokerageLicence}<br />
        Principal broker {BUSINESS.licensing.principalBrokerName}, {BUSINESS.licensing.regulator} agent #{BUSINESS.licensing.principalBrokerLicence}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://lendcity.ca" target="_blank" rel="noopener">
          <button class="rounded-lg bg-primary-100 hover:opacity-90 text-white font-semibold px-8 py-4 text-lg transition-colors">
            Visit LendCity.ca →
          </button>
        </a>
        <a href={BUSINESS.phone.tel}>
          <button class="rounded-lg border-2 border-primary-100 hover:bg-primary-0 text-primary-100 font-semibold px-8 py-4 text-lg transition-colors">
            📞 {BUSINESS.phone.displayDashed}
          </button>
        </a>
      </div>
    </div>
  </section>

  <section class="py-12">
    <div class="container max-w-screen-xl px-6">
      <RelatedLinks slug="/about/" />
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary-100 py-16">
    <div class="container max-w-3xl px-6 text-center">
      <h2 class="text-heading-2 text-white mb-4">Ready to Take Action on Your Renewal?</h2>
      <p class="text-xl text-white/80 mb-8">
        Book a free strategy call with a licensed Canadian mortgage broker. No obligation, no pressure — just expert guidance on your options.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/book-a-call/">
          <button class="rounded-lg bg-warning-100 hover:bg-warning-50 text-gray-900 font-semibold px-8 py-4 text-lg transition-colors">
            Book Free Call
          </button>
        </a>
        <a href="/mortgage-renewal-guide/">
          <button class="rounded-lg border-2 border-white/50 hover:border-white text-white font-semibold px-8 py-4 text-lg transition-colors">
            Read the Guide First
          </button>
        </a>
      </div>
    </div>
  </section>
</DefaultLayout>
