---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import RelatedLinks from "@/components/RelatedLinks.astro";
import { articleSchema, breadcrumbSchema, combineSchemas,serviceSchema, webPageNode } from '@/lib/schema';

export const prerender = true;

const buildDate = new Date().toLocaleDateString("en-CA", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "America/Toronto",
});

const schema = combineSchemas(
  webPageNode({
    slug: "rate-alert",
    name: "Canadian Mortgage Rate Monitoring — Broker Watch Service",
    description: "Have a licensed Canadian mortgage broker watch rates for you across 30+ lenders. Real broker-negotiated rates, not public ones.",
  }),
  serviceSchema({
    name: "Broker Rate Monitoring & Strategy",
    description: "Free service — a licensed broker monitors Canadian mortgage rates across 30+ lenders on your behalf, then contacts you when your target is hit.",
    slug: "rate-alert",
    serviceType: "Mortgage Broker Consultation",
    price: "0",
    priceCurrency: "CAD",
  }),
  articleSchema({
    headline: "Canadian Mortgage Rate Monitoring by a Broker",
    description: "A licensed broker watches rates across 30+ Canadian lenders and contacts you when your target rate is available. Free, no sales pressure.",
    slug: "rate-alert",
    about: "Mortgage Rate Monitoring",
  }),
  breadcrumbSchema([
    { name: "Rate Alerts", url: "/rate-alert" }
  ]),
);
---

<DefaultLayout
  title="Canadian Mortgage Rate Monitoring — Broker Watch"
  description="A licensed broker watches Canadian mortgage rates across 30+ lenders for you. Free service — contact when your target rate is available."
  schema={schema}
>
  <nav class="container py-4 text-body-sm text-muted-foreground">
    <a href="/" class="hover:underline">Home</a> › Rate Alerts
  </nav>

  <section class="container max-w-4xl py-10">
    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <div class="text-body-sm-medium text-secondary-100 uppercase tracking-wide mb-3">Free Service</div>
        <h1 class="text-heading-1 mb-4">Let a Broker Watch Rates For You</h1>
        <p class="text-body-lg text-muted-foreground mb-6">
          Public rate sites show yesterday's posted rates. A licensed Canadian mortgage broker monitors real broker-negotiated rates across 30+ lenders in real time — and contacts you when your target is live. Free service.
        </p>

        <div class="rounded-xl bg-gray-25 border border-gray-100 p-5 mb-6">
          <h2 class="font-semibold mb-3">What you'll get</h2>
          <ul class="space-y-2 text-body-sm">
            <li class="flex gap-2"><span class="text-secondary-100">✓</span><span><strong>Target-rate alert</strong> — single email when the best available rate for your term hits your threshold</span></li>
            <li class="flex gap-2"><span class="text-secondary-100">✓</span><span><strong>Weekly digest</strong> — Monday morning rate snapshot (1-yr through 5-yr fixed, variable)</span></li>
            <li class="flex gap-2"><span class="text-secondary-100">✓</span><span><strong>BoC decision alerts</strong> — next BoC rate decision April 29, 2026</span></li>
            <li class="flex gap-2"><span class="text-secondary-100">✓</span><span><strong>Stop anytime</strong> — one-click unsubscribe in every email</span></li>
          </ul>
        </div>

        <div class="rounded-xl bg-primary-0 border border-primary-25 p-5">
          <p class="text-body-sm-medium text-primary-200 mb-2">Broker rates move daily</p>
          <p class="text-body-sm text-muted-foreground mb-3">
            Public rate sites can be days stale, and broker-channel rates are rarely published at all. For today's live broker-negotiated rate on your term and renewal date, talk to a licensed agent — it's free and takes about 30 minutes.
          </p>
          <a href="/book-a-call/" class="text-body-sm-medium text-primary-200 hover:underline">
            Get today's live rate quote →
          </a>
          <p class="text-body-xs text-muted-foreground mt-3">Page last updated {buildDate}.</p>
        </div>
      </div>

      <div class="rounded-2xl border border-gray-100 bg-white p-6 sm:p-8 shadow-sm">
        <div class="text-body-xs-medium text-secondary-200 uppercase tracking-wide mb-2">Better Than an Alert</div>
        <h2 class="text-heading-4 font-bold mb-4">Have a broker watch rates for you</h2>
        <p class="text-body-md text-muted-foreground mb-5">
          A licensed mortgage broker can monitor rates in real time across 30+ Canadian lenders — not just the ones public rate sites show. Tell them your target rate once, and they reach out when the market hits it.
        </p>

        <div class="rounded-xl bg-secondary-25 border border-secondary-50 p-5 mb-5">
          <p class="text-body-sm-medium mb-3">Why this beats a rate alert email</p>
          <ul class="space-y-2 text-body-sm text-muted-foreground">
            <li class="flex gap-2"><span class="text-secondary-200 flex-shrink-0">→</span><span><strong class="text-foreground">Broker-only rates</strong> are typically 10–25 bps lower than public rate sites show</span></li>
            <li class="flex gap-2"><span class="text-secondary-200 flex-shrink-0">→</span><span><strong class="text-foreground">Rate holds up to 120 days</strong> — once you hit your target, lock it immediately</span></li>
            <li class="flex gap-2"><span class="text-secondary-200 flex-shrink-0">→</span><span><strong class="text-foreground">Real offers, not ranges</strong> — quoted for your specific mortgage and credit</span></li>
            <li class="flex gap-2"><span class="text-secondary-200 flex-shrink-0">→</span><span><strong class="text-foreground">Free service</strong> — brokers are paid by the lender, not you</span></li>
          </ul>
        </div>

        <a href="/book-a-call/" class="block w-full rounded-lg bg-primary-100 text-white font-semibold py-3.5 text-center hover:opacity-90 transition-opacity">
          Book a Free Rate Strategy Call
        </a>

        <p class="text-body-xs text-muted-foreground text-center mt-3">
          30 minutes. No commitment. Unbiased by-lender rate review.
        </p>

        <div class="mt-6 pt-6 border-t border-gray-100">
          <p class="text-body-xs text-muted-foreground">
            Prefer to watch rates yourself? Bookmark our <a href="/current-mortgage-rates-canada/" class="text-secondary-100 hover:underline">current rates page</a> — updated weekly with broker-negotiated rates — and check back before your renewal.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-12 space-y-6">
      <div>
        <h2 class="text-heading-3 mb-3">How Broker Rate Monitoring Works</h2>
        <p class="text-body-md text-muted-foreground mb-3">
          Canadian mortgage rates move in small increments — often 0.05% at a time — but a 0.25% drop over a few weeks can easily mean thousands of dollars over your next 5-year term. Monitoring them yourself means checking rate sites daily and still only seeing the rates lenders publish.
        </p>
        <p class="text-body-md text-muted-foreground">
          When you book a free broker call, you share your target rate, renewal date, and term preference. The broker monitors real broker-channel rates (typically 10–25 bps lower than public posted rates) and contacts you when your target is hit — in time to lock a 120-day rate hold. No sales pressure, no cost.
        </p>
      </div>

      <RelatedLinks slug="/rate-alert/" />
    </div>
  </section>
</DefaultLayout>
