  schema={JSON.stringify({"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://mortgagerenewalhub.ca"},{"@type":"ListItem","position":2,"name":"Services & Pricing","item":"https://mortgagerenewalhub.ca/pricing"}]})}
>
  <ZippayPricingHero />
