---
import RelatedLinks from "@/components/RelatedLinks.astro";
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getPageMeta } from '@/lib/page-meta';
import { articleSchema, breadcrumbSchema, combineSchemas, howToSchema, webPageNode } from '@/lib/schema';

export const pageMeta = getPageMeta("fr/changer-preteur-renouvellement",{
  dateModified: "2026-06-29",
});

export const prerender = true;

const schema = combineSchemas(
  webPageNode({ slug: "fr/changer-preteur-renouvellement", name: "Changer de prêteur au renouvellement", inLanguage: "fr-CA" }),
  articleSchema({
    headline: "Changer de prêteur au renouvellement — Canada",
    description: "Guide FR : transfert au renouvellement, exemption du test de stress (2024), coûts au Québec.",
    slug: "fr/changer-preteur-renouvellement",
    inLanguage: "fr-CA",
    dateModified: "2026-05-22",
  }),
  breadcrumbSchema([
    { name: "Changer de prêteur (FR)", url: "/fr/changer-preteur-renouvellement" },
  ]),
  howToSchema({
    name: "Comment changer de prêteur au renouvellement au Canada",
    description: "Étapes pour transférer votre hypothèque à un nouveau prêteur au renouvellement, incluant l'exemption du test de stress depuis 2024.",
    slug: "fr/changer-preteur-renouvellement",
    inLanguage: "fr-CA",
    steps: [
      { name: "Repérez votre date d'échéance", text: "Confirmez la date exacte de fin de terme sur votre relevé hypothécaire et planifiez 120 jours à l'avance." },
      { name: "Consultez un courtier hypothécaire", text: "Un courtier compare les taux de 30+ prêteurs sans frais pour vous." },
      { name: "Rassemblez vos documents", text: "Relevé hypothécaire récent, preuve de revenu, pièce d'identité et taxe foncière." },
      { name: "Soumettez la demande au nouveau prêteur", text: "Votre courtier soumet la demande; le prêteur émet une lettre d'engagement sous 24 à 72 heures." },
      { name: "Négociez avec votre banque actuelle (optionnel)", text: "Présentez l'offre concurrente à votre prêteur actuel pour voir s'il égale le taux." },
      { name: "Signez l'engagement hypothécaire", text: "Acceptez l'offre du nouveau prêteur; la paperasse se fait souvent en ligne." },
      { name: "Complétez les démarches légales", text: "Un avocat ou notaire inscrit l'hypothèque du nouveau prêteur; au Québec, prévoyez les frais notariaux." },
      { name: "Nouveau terme à l'échéance", text: "À la date d'échéance, l'ancien prêteur est remboursé et le nouveau taux prend effet." },
    ],
  }),
);
---

<DefaultLayout
  title="Changer de prêteur au renouvellement (FR)"
  description="Changer de prêteur au renouvellement : économies, test de stress, frais notariaux au Québec."
  schema={schema}
>
  <article class="container max-w-4xl py-10" lang="fr-CA">
    <p class="text-body-sm mb-2"><a href="/switching-lenders-at-renewal/" class="text-secondary-100 hover:underline">English: Switching lenders</a></p>
    <h1 class="text-heading-1 mb-4">Changer de prêteur au renouvellement</h1>
    <p class="text-body-lg text-muted-foreground mb-6">
      Depuis novembre 2024, un transfert simple au renouvellement (même solde, même amortissement) n'exige plus le test de stress pour les emprunteurs non assurés. Plus de 70 % des Canadiens renouvellent quand même avec leur banque — souvent en payant trop.
    </p>
    <ul class="list-disc list-inside space-y-2 text-body-md text-muted-foreground mb-8">
      <li>Commencez 120 jours avant l'échéance — blocage de taux possible.</li>
      <li>Au Québec : budget notaire obligatoire pour tout changement.</li>
      <li>Utilisez le calculateur : <a href="/switch-vs-stay-calculator/" class="text-secondary-100 hover:underline">rester vs. changer</a>.</li>
    </ul>
    <a href="/book-a-call/" class="inline-block rounded-lg bg-primary-100 text-white px-6 py-3 font-semibold">Appel gratuit avec un courtier</a>
    <RelatedLinks slug="/fr/changer-preteur-renouvellement/" heading="Guides connexes" />
  </article>
</DefaultLayout>
