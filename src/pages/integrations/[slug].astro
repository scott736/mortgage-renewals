---
import { type CollectionEntry,getCollection, render } from "astro:content";

import ZippayCtaCard from "@/components/sections/zippay-cta-card";
import ZippayIntegrationPost from "@/components/sections/zippay-integration-post";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

type IntegrationEntry = CollectionEntry<"integrations">;

export async function getStaticPaths() {
  const entries = await getCollection("integrations");
  return entries.map((entry) => {
    return { params: { slug: entry.id }, props: { entry, slug: entry.id } };
  });
}

const { entry, slug } = Astro.props as {
  entry: IntegrationEntry;
  slug: string;
};

// Frontmatter fields with sensible defaults
const title =
  (typeof entry.data.title === "string" ? entry.data.title.trim() : "") ||
  slug.split("/").pop()!.replace(/-/g, " ");

const category = (entry.data.category ?? "General") as string;
const summary = (entry.data.summary ?? entry.data.description ?? "") as string;
const icon = (entry.data.icon ??
  "/images/integrations/placeholder.svg") as string;
const badges = Array.isArray(entry.data.badges)
  ? entry.data.badges.map(String)
  : [];
const website = entry.data.website?.toString();
const pricing = entry.data.pricing?.toString();
const terms = entry.data.terms?.toString();

// Render MDX body
const { Content } = await render(entry);
---

<DefaultLayout title={`${title} – Integration`} description={summary}>
  <ZippayIntegrationPost
    client:only="react"
    title={title}
    category={category}
    summary={summary}
    icon={icon}
    badges={badges}
    website={website}
    pricing={pricing}
    terms={terms}
  >
    <Content />
  </ZippayIntegrationPost>

  <ZippayCtaCard client:only="react" softBg />
</DefaultLayout>
