---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { articleSchema, breadcrumbSchema, combineSchemas,faqSchema, webPageNode } from '@/lib/schema';
import RelatedLinks from "@/components/RelatedLinks.astro";

export const prerender = true;

const faqs = [
  {
    question: "What's the single most important thing this cheat sheet tells me?",
    answer: "The charge type column. If your existing mortgage is a collateral charge (common at TD, sometimes Scotiabank STEP, sometimes National Bank All-In-One), switching to a new lender involves discharging and re-registering the mortgage — roughly $700–$1,500 in legal fees. Standard charge mortgages can be 'assigned' to a new lender, which many lenders cover under legal-paid switch programs. Knowing your charge type changes the whole switching math."
  },
  {
    question: "Why do Big 6 banks use posted-rate IRD when monolines use fair 3-month interest?",
    answer: "It's a commercial choice. Posted-rate IRD penalties — calculated using the bank's inflated posted rate rather than the discounted rate the customer actually pays — produce dramatically larger penalty amounts, especially in falling-rate environments. First National, MCAP, CMLS, and most monolines use a straightforward 3-month interest penalty (or a discounted-rate IRD), which is typically a fraction of what a Big 6 borrower pays to break the same-size mortgage. This is a well-documented structural cost difference that our IRD explainer covers in detail."
  },
  {
    question: "Are credit union mortgages provincially regulated or federally regulated?",
    answer: "Most Canadian credit unions are provincially regulated — Meridian (Ontario), Vancity (BC), Desjardins (Quebec), Coast Capital Savings (BC), DUCA (Ontario). Provincial regulation means they're not bound by OSFI Guideline B-20 in the same way federally regulated lenders are, though most apply equivalent stress tests voluntarily. A few credit unions, like Coast Capital Savings after its 2020 federal charter, are now federally regulated."
  },
  {
    question: "Which lenders offer the most generous prepayment privileges?",
    answer: "Most Big 6 and monoline lenders offer 15/15 or 20/20 prepayment privileges — meaning you can increase your payment by 15-20% and make lump-sum payments of up to 15-20% of the original balance per year. CIBC's Better Than Prime and some First National products offer 20/20. Monolines tend to be slightly more generous on average, and credit unions vary widely (some as low as 10/10, some as generous as 25/25)."
  },
  {
    question: "What does 'bona fide sale' clause mean in the cheat sheet?",
    answer: "A bona fide sale clause restricts when you can break the mortgage — specifically, it says you can only pay out the mortgage (and the associated IRD penalty) if you are genuinely selling the property to an arm's-length buyer. You cannot break to refinance with a different lender. These clauses are most common in no-frills mortgages at CIBC, RBC, and some monolines, in exchange for a rate discount of roughly 0.10-0.15%. Avoid them unless you are certain you won't want to refinance mid-term."
  }
];

const schema = combineSchemas(
  articleSchema({
    headline: "Canadian Mortgage Lender Cheat Sheet 2026: Charge Type, Portability, IRD, Prepay",
    description: "Comprehensive 2026 comparison table of Canadian mortgage lenders — charge type, portability, IRD method, blend-and-extend, skip-a-payment, prepayment privileges. Big 6, monolines, credit unions, B-lenders.",
    slug: "canadian-lender-cheat-sheet",
    articleSection: "Reference",
    about: "Canadian mortgage lender comparison",
    keywords: ["Canadian mortgage lenders", "collateral vs standard charge", "IRD method", "mortgage lender comparison", "prepayment privileges Canada"],
  }),
  breadcrumbSchema([
    { name: "Canadian Lender Cheat Sheet", url: "/canadian-lender-cheat-sheet" }
  ]),
  faqSchema(faqs, "canadian-lender-cheat-sheet"),
  webPageNode({
    slug: "canadian-lender-cheat-sheet",
    name: "Canadian Mortgage Lender Cheat Sheet (2026)",
    description: "Comprehensive comparison of Canadian mortgage lenders — charge type, portability, IRD method, prepayment privileges, and 2026 stance.",
  }),
);
