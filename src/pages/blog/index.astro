---
import { type CollectionEntry,getCollection } from "astro:content";

import ZippayBlogFeaturedPosts from "@/components/sections/zippay-blog-featured-posts";
import ZippayBlogGrid, {
  type BlogCard,
} from "@/components/sections/zippay-blog-grid";
import ZippayBlogHero from "@/components/sections/zippay-blog-header";
import ZippayCtaCard from "@/components/sections/zippay-cta-card";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

type BlogEntry = CollectionEntry<"blog">;

const all: BlogEntry[] = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const allPosts = all.map((p) => ({
  slug: p.id,
  title: p.data.title ?? p.id.replace(/-/g, " "),
  description: p.data.intro ?? "",
  tagline: p.data.tagline ?? "",
  tags: p.data.tags ?? [],
  featured: !!p.data.featured,
  coverImage:
    p.data.coverImage ?? p.data.image ?? "/images/blog/placeholder.webp",
  published: p.data.published?.toISOString?.(),
}));

const featuredPosts = allPosts.filter((p) => p.featured);

const gridPosts: BlogCard[] = allPosts.map((p) => {
  const chip = p.tagline?.trim?.() || p.tags?.[0]?.trim?.() || "General";
  return {
    slug: p.slug,
    title:
      (typeof p.title === "string" ? p.title.trim() : "") ||
      p.slug.replace(/-/g, " "),
    tagline: chip,
    category: chip,
    intro: p.description ?? "",
  };
});
---

<DefaultLayout title="Blog" description="Latest posts">
  <ZippayBlogHero client:load />
  {
    featuredPosts.length > 0 && (
      <ZippayBlogFeaturedPosts client:load posts={featuredPosts} />
    )
  }
  <ZippayBlogGrid client:load posts={gridPosts} />
  <ZippayCtaCard client:load softBg />
</DefaultLayout>
