---
export const prerender = true;

import { type CollectionEntry,getCollection, render } from "astro:content";

import ZippayBlogPost from "@/components/sections/zippay-blog-post";
import ZippayCtaCard from "@/components/sections/zippay-cta-card";
import DefaultLayout from "@/layouts/DefaultLayout.astro";

type BlogEntry = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: post,
    }));
}

const post = Astro.props as BlogEntry;

const title = post.data.title;
const tagline = post.data.tagline ?? "";
const intro = post.data.intro ?? "";
const author = post.data.author ?? "";
const image =
  post.data.coverImage ?? post.data.image ?? "/images/blog/placeholder.webp";
const publishedISO = post.data.published.toISOString();

const { Content } = await render(post);

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": intro,
  "image": new URL(image, Astro.site).toString(),
  "datePublished": publishedISO,
  "author": {
    "@type": "Person",
    "name": author || "MortgageRenewalHub.ca"
  },
  "publisher": {
    "@type": "Organization",
    "name": "MortgageRenewalHub.ca",
    "logo": {
      "@type": "ImageObject",
      "url": "https://mortgagerenewalhub.ca/favicon/favicon-96x96.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  }
});
---

<DefaultLayout title={title} description={intro} schema={articleSchema}>
  <ZippayBlogPost
    client:only="react"
    tagline={tagline}
    title={title}
    intro={intro}
    image={image}
    author={author}
    published={publishedISO}
  >
    <Content />
  </ZippayBlogPost>

  <ZippayCtaCard client:only="react" softBg={true} />
</DefaultLayout>
