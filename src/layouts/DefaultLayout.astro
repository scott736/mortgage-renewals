---
import VercelAnalytics from "@/components/analytics/VercelAnalytics";
import AuthorByline from "@/components/AuthorByline.astro";
import BaseHead from "@/components/BaseHead.astro";
import Banner from "@/components/sections/banner";
import ClickToCallBar from "@/components/sections/click-to-call-bar";
import Footer from "@/components/sections/footer";
import MobileStickyCta from "@/components/sections/mobile-sticky-cta";
import Navbar from "@/components/sections/navbar";

const { title, description, schema, preloadImage, noindex, ogType, hideAuthorByline, hideMobileSticky } = Astro.props;

const detectedOgType =
  ogType ||
  (schema && /"@type"\s*:\s*"Article"/.test(schema) ? "article" : "website");

const isArticlePage = Boolean(schema && /"@type"\s*:\s*"Article"/.test(schema));
const schemaDateModified = schema?.match(/"dateModified"\s*:\s*"([^"]+)"/)?.[1];
const showAuthorByline = isArticlePage && !hideAuthorByline;
const pageLang = Astro.url.pathname.startsWith("/fr/") ? "fr-CA" : "en-CA";
---

<html lang={pageLang} class="dark">
  <head>
    <BaseHead title={title} description={description} schema={schema} preloadImage={preloadImage} noindex={noindex} ogType={detectedOgType} />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const theme = stored ?? "light";
          document.documentElement.classList.toggle("dark", theme === "dark");
        } catch {}
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased pb-24 lg:pb-0">
    <VercelAnalytics client:load />
    <Banner client:idle />
    <Navbar client:idle />
    <main>
      {showAuthorByline && (
        <div class="container max-w-4xl pt-4 pb-0">
          <AuthorByline dateModified={schemaDateModified} />
        </div>
      )}
      <slot />
    </main>
    <Footer />
    {!hideMobileSticky && <MobileStickyCta client:idle />}
    <ClickToCallBar client:idle />
  </body>
</html>
