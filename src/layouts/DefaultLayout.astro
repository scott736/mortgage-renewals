---
import AuthorByline from "@/components/AuthorByline.astro";
import BaseHead from "@/components/BaseHead.astro";
import LastUpdated from "@/components/LastUpdated.astro";
import Banner from "@/components/sections/banner";
import ClickToCallBar from "@/components/sections/click-to-call-bar";
import ExitIntentModal from "@/components/sections/exit-intent-modal";
import Footer from "@/components/sections/footer";
import MobileStickyCta from "@/components/sections/mobile-sticky-cta";
import Navbar from "@/components/sections/navbar";

const {
  title,
  description,
  schema,
  preloadImage,
  noindex,
  ogType,
  hideAuthorByline,
  hideMobileSticky,
  lastUpdated,
  showExitIntent: showExitIntentProp,
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCalculatorOrRatesPage =
  pathname.includes("-calculator") ||
  /\/(best-mortgage-renewal-rates|current-mortgage-rates-canada|bank-of-canada-rate-decisions|mortgage-rate-forecast|rate-alert)/.test(pathname);
const showExitIntent = showExitIntentProp ?? isCalculatorOrRatesPage;
const exitIntentStorageKey = `exit-intent${pathname.replace(/\//g, "-")}`;

const detectedOgType =
  ogType ||
  (schema && /"@type"\s*:\s*"Article"/.test(schema) ? "article" : "website");

const isArticlePage = Boolean(schema && /"@type"\s*:\s*"Article"/.test(schema));
const schemaDateModified = schema?.match(/"dateModified"\s*:\s*"([^"]+)"/)?.[1];
const showLastUpdated = Boolean(lastUpdated);
const showAuthorByline = isArticlePage && !hideAuthorByline && !showLastUpdated;
const pageLang = Astro.url.pathname.startsWith("/fr/") ? "fr-CA" : "en-CA";
---

<html lang={pageLang}>
  <head>
    <BaseHead title={title} description={description} schema={schema} preloadImage={preloadImage} noindex={noindex} ogType={detectedOgType} />
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "74e0ed1edd694318851f835cc6f8b4d5"}'
    ></script>
  </head>
  <body class="min-h-screen antialiased pb-24 lg:pb-0">
    <Banner client:idle />
    <Navbar client:idle />
    <main>
      {showLastUpdated && (
        <div class="container max-w-4xl pt-4 pb-0">
          <LastUpdated dateModified={lastUpdated} />
        </div>
      )}
      {showAuthorByline && (
        <div class="container max-w-4xl pt-4 pb-0">
          <AuthorByline dateModified={schemaDateModified} />
        </div>
      )}
      <slot />
    </main>
    <Footer />
    {!hideMobileSticky && <MobileStickyCta client:idle />}
    <ClickToCallBar client:idle />
    {showExitIntent && (
      <ExitIntentModal client:idle storageKey={exitIntentStorageKey} />
    )}
  </body>
</html>
