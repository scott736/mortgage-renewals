---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";

import { Font } from "astro:assets";

import { BUSINESS, POSTAL_ADDRESS_NODE, SITE_METADATA } from "../consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  schema?: string;
  preloadImage?: string;
  noindex?: boolean;
  /** OpenGraph object type. Defaults to "website"; pages with Article schema should set "article". */
  ogType?: "website" | "article";
}

// Normalize canonical URL to always end with a single trailing slash so it
// matches the sitemap output (Astro `trailingSlash: "always"`).
const normalizedPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = new URL(normalizedPath, Astro.site);

const { title, description, image, schema, preloadImage, noindex = false, ogType = "website" } = Astro.props;
const finalTitle = title || SITE_METADATA.title.default;
const finalDescription = description || SITE_METADATA.description;
const finalImage = image || SITE_METADATA.openGraph.images[0].url;
const imageURL = new URL(finalImage, Astro.url);

const robotsContent = noindex
  ? "noindex, nofollow"
  : `${SITE_METADATA.robots.index ? "index" : "noindex"}, ${SITE_METADATA.robots.follow ? "follow" : "nofollow"}`;

// Build a single connected @graph rather than disconnected nodes. This lets
// schema parsers (Google, Perplexity, Claude) cross-reference the Organization
// from Article publisher fields, and the WebSite from page-level WebPage nodes.
const ORG_ID = "https://mortgagerenewalhub.ca/#organization";
const SITE_ID = "https://mortgagerenewalhub.ca/#website";

const organizationNode = {
  "@type": ["Organization", "FinancialService"],
  "@id": ORG_ID,
  name: "MortgageRenewalHub.ca",
  legalName: "LendCity Mortgages",
  url: "https://mortgagerenewalhub.ca",
  logo: {
    "@type": "ImageObject",
    url: "https://mortgagerenewalhub.ca/favicon/favicon-96x96.png",
    width: 96,
    height: 96,
  },
  image: "https://mortgagerenewalhub.ca/og-image.jpg",
  description: SITE_METADATA.description,
  foundingDate: "2024",
  telephone: BUSINESS.phone.e164,
  parentOrganization: {
    "@type": "Organization",
    name: BUSINESS.parent.name,
    url: BUSINESS.parent.url,
    telephone: BUSINESS.phone.e164,
    address: POSTAL_ADDRESS_NODE,
  },
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "customer service",
      telephone: BUSINESS.phone.e164,
      url: "https://mortgagerenewalhub.ca/contact/",
      availableLanguage: ["English", "French"],
      areaServed: "CA",
    },
  ],
  address: POSTAL_ADDRESS_NODE,
  areaServed: {
    "@type": "Country",
    name: "Canada",
  },
  knowsAbout: [
    "Mortgage Renewal",
    "Canadian Mortgage Rates",
    "Mortgage Refinancing",
    "Fixed vs Variable Mortgages",
    "Mortgage Broker Services",
    "Canadian Mortgage Charter",
    "Bank of Canada Policy Rate",
    "Mortgage Stress Test",
  ],
  sameAs: ["https://lendcity.ca"],
};

const websiteNode = {
  "@type": "WebSite",
  "@id": SITE_ID,
  name: "MortgageRenewalHub.ca",
  url: "https://mortgagerenewalhub.ca",
  description: SITE_METADATA.description,
  publisher: { "@id": ORG_ID },
  inLanguage: "en-CA",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate:
        "https://mortgagerenewalhub.ca/mortgage-renewal-calculator?q={search_term_string}",
    },
    "query-input": "required name=search_term_string",
  },
};

// If the page passed schema, parse it back out so we can merge into the @graph.
let pageSchemaNodes: unknown[] = [];
if (schema) {
  try {
    const parsed = JSON.parse(schema);
    pageSchemaNodes = Array.isArray(parsed) ? parsed : [parsed];
  } catch {
    pageSchemaNodes = [];
  }
}

const graphSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [organizationNode, websiteNode, ...pageSchemaNodes],
});
---

<!-- Global Metadata -->
<meta charset="utf-8" />

<!-- Hero image preload (LCP optimization) -->
{preloadImage && (
  <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
)}

<!-- Fonts (Astro 6 Fonts API) -->
<Font cssVariable="--font-satoshi" preload />

<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={robotsContent} />
<meta name="keywords" content={SITE_METADATA.keywords.join(", ")} />
<meta name="author" content={SITE_METADATA.authors[0].name} />
<meta name="creator" content={SITE_METADATA.creator} />
<meta name="publisher" content={SITE_METADATA.publisher} />

<!-- Theme Script -->
<script is:inline>
  // Get theme from localStorage or system preference
  const savedTheme = localStorage.getItem("theme");
  const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
    ? "dark"
    : "light";
  const initialTheme = savedTheme || systemTheme;

  // Apply theme immediately to prevent flashing
  document.documentElement.classList.toggle("dark", initialTheme === "dark");
</script>

<!-- Favicon -->
{
  SITE_METADATA.icons.icon.map((icon) => (
    <link rel="icon" type={icon.type} sizes={icon.sizes} href={icon.url} />
  ))
}
{
  SITE_METADATA.icons.apple.map((icon) => (
    <link rel="apple-touch-icon" sizes={icon.sizes} href={icon.url} />
  ))
}
{
  SITE_METADATA.icons.shortcut.map((icon) => (
    <link rel="shortcut icon" href={icon.url} />
  ))
}

<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL (matches sitemap trailing-slash convention) -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="en-ca" href={canonicalURL} />
<link rel="alternate" hreflang="x-default" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{finalTitle}</title>
<meta name="title" content={finalTitle} />
<meta name="description" content={finalDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:locale" content="en_CA" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_METADATA.openGraph.siteName} />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:image" content={imageURL} />
<meta
  property="og:image:width"
  content={SITE_METADATA.openGraph.images[0].width.toString()}
/>
<meta
  property="og:image:height"
  content={SITE_METADATA.openGraph.images[0].height.toString()}
/>
<meta property="og:image:alt" content={SITE_METADATA.openGraph.images[0].alt} />

<!-- Twitter -->
<meta name="twitter:card" content={SITE_METADATA.twitter.card} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={imageURL} />
{SITE_METADATA.twitter.creator && (
  <meta name="twitter:creator" content={SITE_METADATA.twitter.creator} />
)}

<!-- Structured Data: Single connected @graph (Organization + WebSite + page schemas) -->
<script type="application/ld+json" set:html={graphSchema} />
