---
import { DEFAULT_AUTHOR } from "@/lib/schema";

interface Props {
  dateModified?: string;
  class?: string;
  showPhoto?: boolean;
}

const { dateModified, class: className, showPhoto = false } = Astro.props;
const author = DEFAULT_AUTHOR;

function formatDate(iso?: string): string {
  if (!iso) return new Date().toLocaleDateString("en-CA", { year: "numeric", month: "long" });
  const d = new Date(iso + "T12:00:00");
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString("en-CA", { year: "numeric", month: "long", day: "numeric" });
}

const updated = formatDate(dateModified);
---

<div
  class:list={[
    showPhoto ? "flex items-center gap-3" : "",
    className,
  ]}
  data-speakable
>
  {showPhoto && (
    <img
      src="/images/hero/hero-broker.webp"
      alt={`${author.name} — ${author.jobTitle}`}
      width={48}
      height={48}
      loading="lazy"
      decoding="async"
      class="size-12 rounded-full object-cover ring-2 ring-gray-100 shrink-0"
    />
  )}
  <p class="text-body-sm text-muted-foreground">
    Reviewed by{" "}
    <a href={`${author.url}#scott-dillingham`} class="font-medium text-secondary-100 hover:underline">
      {author.name}
    </a>
    {author.jobTitle && (
      <span class="text-muted-foreground"> · {author.jobTitle}</span>
    )}
    {" "}· Updated {updated}
  </p>
</div>
