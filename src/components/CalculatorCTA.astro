---
interface Props {
  title: string;
  description: string;
  href: string;
  buttonLabel?: string;
  embed?: boolean;
}

const { title, description, href, buttonLabel = "Open calculator", embed = false } = Astro.props;
---

<div class="rounded-xl border border-secondary-50 bg-secondary-25 p-6 my-8">
  <h3 class="text-heading-5 mb-2">{title}</h3>
  <p class="text-body-sm text-muted-foreground mb-4">{description}</p>
  {embed ? (
    <slot />
  ) : (
    <a
      href={href}
      class="inline-flex rounded-lg bg-primary-100 text-white px-5 py-2.5 text-body-sm-medium hover:opacity-90 transition-opacity"
    >
      {buttonLabel} →
    </a>
  )}
</div>
