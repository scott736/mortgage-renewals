---
import { getRelated } from "@/data/internal-links";

interface Props {
  slug: string;
  heading?: string;
  className?: string;
}

const { slug, heading = "Related Guides", className = "" } = Astro.props;
const items = getRelated(slug);
---

{items.length > 0 && (
  <div class={`mt-12 border-t pt-8 ${className}`} style="border-color: var(--border)">
    <h2 class="text-xl font-bold mb-4" style="color: var(--primary)">{heading}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {items.map((item) => (
        <a
          href={item.href}
          class="rounded-lg p-4 transition-colors hover:bg-gray-25"
          style="border: 1px solid var(--border); background: var(--card)"
        >
          <p class="font-semibold text-sm mb-1" style="color: var(--primary)">
            {item.title}
          </p>
          <p class="text-xs" style="color: var(--muted-foreground)">
            {item.blurb}
          </p>
        </a>
      ))}
    </div>
  </div>
)}
