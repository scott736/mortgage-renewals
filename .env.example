# MortgageRenewalHub.ca environment variables
# Copy this file to `.env` for local dev and set the same keys in the Vercel
# dashboard (Project Settings → Environment Variables) for Preview + Production.

# === Nylas (booking calendar) ===
# Server API key + client ID from https://dashboard-v3.nylas.com/
NYLAS_API_KEY=
NYLAS_CLIENT_ID=
# Optional region override — defaults to https://api.us.nylas.com
# NYLAS_API_URI=https://api.us.nylas.com
# Secret for verifying inbound Nylas webhooks (only required if you add webhook handlers)
# NYLAS_WEBHOOK_SECRET=

# === Elastic Email (transactional email) ===
# Used by /api/nylas/book, /api/nylas/confirm, /api/contact
# Create an API key at https://app.elasticemail.com/api/settings/api-keys
ELASTIC_EMAIL_API_KEY=

# === Upstash Redis (durable pending-booking store) ===
# Provision via Vercel Marketplace → Upstash — these are auto-populated on Vercel.
# For local dev, create a free Upstash database and paste the REST URL + token here.
# Falls back to in-memory storage if unset (acceptable for local dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
